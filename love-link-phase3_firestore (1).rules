rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — readable by any authenticated user (invite code lookup)
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Couples — only members can read/write
    match /couples/{coupleId} {
      allow read:   if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid in resource.data.members;
      allow delete: if false;

      function isMember() {
        return request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
      }

      // Phase 1 & 2 collections
      match /messages/{id}   { allow read, write: if isMember(); }
      match /gifts/{id}      { allow read, write: if isMember(); }
      match /memories/{id}   { allow read, write: if isMember(); }
      match /notes/{id}      { allow read, write: if isMember(); }
      match /vibes/{id}      { allow read, write: if isMember(); }
      match /dates/{id}      { allow read, write: if isMember(); }
      match /quiz/{id}       { allow read, write: if isMember(); }
      match /bucketlist/{id} { allow read, write: if isMember(); }
      match /letters/{id}    { allow read, write: if isMember(); }
      match /checkins/{id}   { allow read, write: if isMember(); }

      // Phase 3 collections
      match /daily/{id}      { allow read, write: if isMember(); }
      match /missions/{id}   { allow read, write: if isMember(); }
      match /drawings/{id}   { allow read, write: if isMember(); }
      match /strokes/{id}    { allow read, write: if isMember(); }
      match /sync/{id}       { allow read, write: if isMember(); }
      match /sync_chat/{id}  { allow read, write: if isMember(); }
      match /story/{id}      { allow read, write: if isMember(); }
      match /private/{id}    { allow read, write: if isMember(); }
      match /reactions/{id}  { allow read, write: if isMember(); }
      match /hub_items/{id}  { allow read, write: if isMember(); }
    }

    // Live snaps — sender/receiver access
    match /live_snaps/{snapId} {
      allow read:   if request.auth != null &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.receiverId == request.auth.uid);
      allow delete: if request.auth != null &&
        resource.data.senderId == request.auth.uid;
    }
  }
}
