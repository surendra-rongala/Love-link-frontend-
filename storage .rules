rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Couple media — members only
    match /couples/{coupleId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    // Live snaps — authenticated users
    match /snaps/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    // Drawings — authenticated users
    match /drawings/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
